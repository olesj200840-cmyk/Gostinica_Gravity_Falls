<Window x:Class="Gostinica.Admin_vxod"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gostinica"
        mc:Ignorable="d"
        Title=""  
        Height="300" Width="300" WindowStyle="None" 
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
            <ImageBrush ImageSource="C:\Users\Александр\Desktop\von2.png"/>
        </Window.Background>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button Height="12" Width="12" Margin="280,1,0,0"
        Content="x" Foreground="White" 
        Background="Transparent"
        Opacity="1" FontSize="6" Click="exit_admin_vxod"/>
        <Grid Grid.Row="1" Margin="20,60,20,70" Opacity="1" Background="#344B73">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>

                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            <TextBlock  Grid.Row="1" TextAlignment="Center" 
        TextWrapping="Wrap"  x:Name="MessageTextBlockAdmin"
        Text="" FontSize="20" Padding="10"
        Foreground="White" FontWeight="Bold"/>
        <TextBlock x:Name="Privet" Margin="5" Text="Вход в систему админа"
               FontSize="16" 
               FontWeight="Bold" TextAlignment="Center" 
               Foreground="White"/>
        <TextBlock x:Name="vod_posword" Grid.Row="1" Height="20" Width="100" 
               Margin="10,30,150,30" 
               Foreground="White"  FontFamily="Myanmar Text"
               Text="Введите пароль:" />
        <PasswordBox x:Name="PaswordAdmin" Grid.Row="1" Height="19" 
                 Width="130" IsEnabled="True"
                 Margin="110,30,20,30" PasswordChar="*" FontSize="16"/>
        <Button x:Name="Button_vxodAdmin" Grid.Row="2" 
            Height="20" Width="80" 
            Margin="75,0,85,10" Content="Вход"
            Background="White" Click="Pasword_Admin"/>
        <TextBlock x:Name="MessageText"
               Grid.Row="1" TextAlignment="Center" 
               Height="20" 
               Text="" FontSize="11"
               Margin="0,54,0,6" Foreground="Red"/>

        </Grid>
    </Grid>
</Window>
